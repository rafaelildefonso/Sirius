{
  "identifier": "default",
  "description": "Default capabilities for SIRIUS",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "sirius-backend",
          "sidecar": true
        }
      ]
    },
    "shell:default"
  ]
}
