# Sirius — Environment Variables
# Copy this file to .env and fill in your keys

## Gemini AI
GEMINI_API_KEY=

## OpenRouter
OPENROUTER_API_KEY=

## Tavily Search
TAVILY_API_KEY=

## SerpAPI
SERPAPI_KEY=

## Google OAuth 2.0 (Desktop app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Notion Integration
NOTION_TOKEN=
NOTION_DATABASE_ID=

## Operating system override (windows, mac, linux)
OS_SYSTEM=windows
